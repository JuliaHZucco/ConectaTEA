<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_screen_blue"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:id="@+id/tvChildName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/title_purple"
            android:textSize="26sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnMorningTable"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="20dp"
            android:background="@drawable/bg_button_primary"
            android:text="Rotina da manhã"
            android:textAllCaps="false"
            android:textColor="@color/text_white" />

        <Button
            android:id="@+id/btnSchoolTable"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_button_secondary"
            android:text="Escola"
            android:textAllCaps="false"
            android:textColor="@color/text_white" />

        <Button
            android:id="@+id/btnNewTable"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_button_tertiary"
            android:text="Nova tabela de pictogramas"
            android:textAllCaps="false"
            android:textColor="@color/text_white" />

        <Button
            android:id="@+id/btnBack"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="18dp"
            android:background="@drawable/bg_button_tertiary"
            android:text="Voltar"
            android:textAllCaps="false"
            android:textColor="@color/text_white" />
    </LinearLayout>
</ScrollView>